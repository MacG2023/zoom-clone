{
  "appId": "com.zoomclone.app",
  "productName": "ZoomClone",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "out/**/*"
  ],
  "protocols": {
    "name": "ZoomClone Meeting",
    "schemes": ["zoomclone"]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": true,
    "allowToChangeInstallationDirectory": false,
    "createDesktopShortcut": true,
    "shortcutName": "ZoomClone"
  },
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage"
  }
}
